# PBB backend environment variables.
# On Railway, set these as service variables (do NOT commit a real .env).

# Provided automatically by the Railway Postgres plugin:
DATABASE_URL="postgresql://user:password@host:5432/railway"

# The first owner account, seeded on first boot if no admin user exists yet.
# Choose your own; you can change the password after first login.
ADMIN_EMAIL="owner@yourdomain.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Set to "true" in production so the session cookie is marked Secure (HTTPS only).
# Leave unset locally (http://localhost).
COOKIE_SECURE="true"

# Railway provides PORT automatically; no need to set it.
